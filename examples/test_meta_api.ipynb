{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# META API Request Test\n",
    "\n",
    "This notebook submits a test request to the META API endpoint.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "import json\n",
    "\n",
    "# Add project root to path\n",
    "project_root = Path.cwd().parent\n",
    "if str(project_root) not in sys.path:\n",
    "    sys.path.insert(0, str(project_root))\n",
    "\n",
    "print(f\"Project root: {project_root}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import required modules\n",
    "from src.scheduler.scheduler_settings import SchedulerSettings\n",
    "from src.decorators import handle_api_request\n",
    "from src.debug_config import DebugConfig\n",
    "\n",
    "print(\"✓ Imports successful\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 1: Load Configuration\n",
    "\n",
    "Load API credentials from environment variables."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize settings to get API key from environment\n",
    "settings = SchedulerSettings.initialize()\n",
    "ready_agents = settings.get_ready_agents()\n",
    "\n",
    "# Get META agent configuration\n",
    "meta_config = ready_agents.get(\"META\")\n",
    "\n",
    "if not meta_config:\n",
    "    print(\"❌ META agent not configured\")\n",
    "    print(f\"Available agents: {list(ready_agents.keys())}\")\n",
    "else:\n",
    "    print(f\"✓ META agent configured\")\n",
    "    print(f\"  Endpoint: {meta_config.api_endpoint}\")\n",
    "    print(f\"  API Key present: {bool(meta_config.api_key)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 2: Prepare Request Parameters\n",
    "\n",
    "Set up the request parameters for the META API search."
   ]
  },
  {
   "cell_type": "code">
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Request parameters\n",
    "url = \"https://api.metaso.cn/search\"\n",
    "method = \"POST\"\n",
    "description = \"meta_search\"\n",
    "\n",
    "json_body = {\n",
    "    \"q\": \"人工智能 大模型\",\n",
    "    \"scope\": \"webpage\",\n",
    "    \"size\": \"5\",\n",
    "    \"includeSummary\": False,\n",
    "    \"includeRawContent\": True,\n",
    "    \"conciseSnippet\": False\n",
    "}\n",
    "\n",
    "headers = {\n",
    "    \"Authorization\": f\"Bearer {meta_config.api_key}\",\n",
    "    \"Accept\": \"application/json\",\n",
    "    \"Content-Type\": \"application/json\"\n",
    "}\n",
    "\n",
    "timeout = 30\n",
    "\n",
    "print(\"Request Configuration:\")\n",
    "print(f\"  URL: {url}\")\n",
    "print(f\"  Method: {method}\")\n",
    "print(f\"  Description: {description}\")\n",
    "print(f\"  Timeout: {timeout}s\")\n",
    "print()\n",
    "print(\"Request Body:\")\n",
    "print(json.dumps(json_body, indent=2, ensure_ascii=False))\n",
    "print()\n",
    "print(\"Headers:\")\n",
    "print(f\"  Authorization: Bearer {meta_config.api_key[:20]}...\")\n",
    "print(f\"  Accept: {headers['Accept']}\")\n",
    "print(f\"  Content-Type: {headers['Content-Type']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: Submit Request\n",
    "\n",
    "Submit the request using the centralized `handle_api_request()` function."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Enable debug mode for better logging\n",
    "DebugConfig.DEBUG = True\n",
    "DebugConfig.fake_response_enabled = False  # Disable fake responses to call real API\n",
    "\n",
    "print(\"\\n📡 Submitting request to META API...\\n\")\n",
    "\n",
    "try:\n",
    "    response = handle_api_request(\n",
    "        agent_name=\"META\",\n",
    "        url=url,\n",
    "        method=method,\n",
    "        description=description,\n",
    "        json_body=json_body,\n",
    "        headers=headers,\n",
    "        timeout=timeout,\n",
    "        query_request=None\n",
    "    )\n",
    "    \n",
    "    print(\"✓ Request successful!\")\n",
    "    print()\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"❌ Request failed: {e}\")\n",
    "    import traceback\n",
    "    traceback.print_exc()\n",
    "    response = None"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: Display Response\n",
    "\n",
    "Show the response data from the API."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if response:\n",
    "    print(\"Response Summary:\")\n",
    "    print(f\"  Response type: {type(response).__name__}\")\n",
    "    print(f\"  Response keys: {list(response.keys()) if isinstance(response, dict) else 'N/A'}\")\n",
    "    print()\n",
    "    \n",
    "    if isinstance(response, dict):\n",
    "        # Check for webpages (META response format)\n",
    "        if 'webpages' in response:\n",
    "            webpages = response.get('webpages', {})\n",
    "            results = webpages.get('value', [])\n",
    "            print(f\"Results returned: {len(results)}\")\n",
    "            print()\n",
    "            \n",
    "            if results:\n",
    "                print(\"First Result:\")\n",
    "                first = results[0]\n",
    "                print(f\"  Title: {first.get('title', 'N/A')}\")\n",
    "                print(f\"  URL: {first.get('url', 'N/A')}\")\n",
    "                print(f\"  Snippet: {first.get('snippet', 'N/A')[:100]}...\")\n",
    "                print()\n",
    "        \n",
    "        # Display full response (pretty-printed)\n",
    "        print(\"Full Response:\")\n",
    "        print(json.dumps(response, indent=2, ensure_ascii=False)[:1000])  # First 1000 chars\n",
    "else:\n",
    "    print(\"No response received\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5: Analyze Response Structure\n",
    "\n",
    "Examine the response structure for further processing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if response and isinstance(response, dict):\n",
    "    print(\"Response Structure Analysis:\")\n",
    "    print()\n",
    "    \n",
    "    # Show top-level keys\n",
    "    print(\"Top-level keys:\")\n",
    "    for key in response.keys():\n",
    "        value = response[key]\n",
    "        if isinstance(value, dict):\n",
    "            print(f\"  {key}: dict with {len(value)} items\")\n",
    "        elif isinstance(value, list):\n",
    "            print(f\"  {key}: list with {len(value)} items\")\n",
    "        else:\n",
    "            print(f\"  {key}: {type(value).__name__}\")\n",
    "    \n",
    "    # If webpages exists, analyze it\n",
    "    if 'webpages' in response:\n",
    "        print()\n",
    "        print(\"Webpages structure:\")\n",
    "        webpages = response['webpages']\n",
    "        for key in webpages.keys():\n",
    "            value = webpages[key]\n",
    "            if isinstance(value, dict):\n",
    "                print(f\"  {key}: dict with {len(value)} items\")\n",
    "            elif isinstance(value, list):\n",
    "                print(f\"  {key}: list with {len(value)} items\")\n",
    "            else:\n",
    "                print(f\"  {key}: {type(value).__name__} = {value}\")\n",
    "else:\n",
    "    print(\"No response data to analyze\")"
   ]
  }
 ],
